{
  "name": "@wazobiatech/helios-permissions",
  "version": "0.8.0",
  "description": "TypeScript SDK for the Nexus permission contract — Redis-cached callerHasPermission, NestJS module, and event-driven cache invalidation. Role-permissions are codegen'd from wazobiatech/permission-contract.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./cache": {
      "import": {
        "types": "./dist/cache/index.d.ts",
        "default": "./dist/cache/index.js"
      },
      "require": {
        "types": "./dist/cache/index.d.ts",
        "default": "./dist/cache/index.js"
      }
    },
    "./helios": {
      "import": {
        "types": "./dist/helios/index.d.ts",
        "default": "./dist/helios/index.js"
      },
      "require": {
        "types": "./dist/helios/index.d.ts",
        "default": "./dist/helios/index.js"
      }
    },
    "./nestjs": {
      "import": {
        "types": "./dist/nestjs/index.d.ts",
        "default": "./dist/nestjs/index.js"
      },
      "require": {
        "types": "./dist/nestjs/index.d.ts",
        "default": "./dist/nestjs/index.js"
      }
    },
    "./role-permissions": {
      "import": {
        "types": "./dist/role-permissions.d.ts",
        "default": "./dist/role-permissions.js"
      },
      "require": {
        "types": "./dist/role-permissions.d.ts",
        "default": "./dist/role-permissions.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "codegen": "node scripts/codegen-permissions.mjs",
    "prebuild": "yarn codegen",
    "prepublishOnly": "yarn codegen && yarn build",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --ci --coverage --verbose",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "permissions",
    "rbac",
    "nexus",
    "wazobia",
    "helios"
  ],
  "author": "Wazobia Tech",
  "license": "MIT",
  "devDependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "reflect-metadata": "^0.1.14",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "ioredis": "^5.4.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    }
  }
}
